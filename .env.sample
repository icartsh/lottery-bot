# Default Setup
USERNAME=YOURID
PASSWORD=YOUR_PASSWORD
COUNT=5

# 직접 고른 번호로 구매할 게임 (선택). 비워두면 COUNT 만큼 전부 자동.
# 한 게임은 1~45 사이 번호 6개를 콤마로, 여러 게임은 세미콜론(;)으로 구분합니다.
# 지정한 게임이 앞 슬롯(A, B...)을 차지하고 나머지는 자동으로 채워집니다.
#   MANUAL_NUMBERS=1,7,13,22,33,45                   -> 수동 1장 + 자동 (COUNT-1)장
#   MANUAL_NUMBERS=1,7,13,22,33,45;2,9,14,20,31,42   -> 수동 2장 + 자동 (COUNT-2)장
MANUAL_NUMBERS=

# For Notifications
SLACK_WEBHOOK_URL = YOUR_SLACK_WEBHOOK_URL
DISCORD_WEBHOOK_URL = YOUR_DISCORD_WEBHOOK_URL
TELEGRAM_BOT_TOKEN = YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID = YOUR_TELEGRAM_CHAT_ID